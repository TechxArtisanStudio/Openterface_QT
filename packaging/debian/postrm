#!/bin/bash
set -e

# Clean up any legacy bundled library configuration on removal
if [ "$1" = "remove" ] || [ "$1" = "purge" ]; then
    # Keep this for compatibility with older versions that created the file.
    rm -f /etc/ld.so.conf.d/openterface-libs.conf
    
    # Do NOT enforce global ldconfig behavior in new installs; leave updates to the administrator.
    echo "OpenterfaceQT: Legacy ld.so.conf.d file removed (if present)"
fi

exit 0
